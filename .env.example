APP_NAME=app-finanzas-api
API_PREFIX=/api/v1
SECRET_KEY=change-me-use-a-long-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080
JWT_ALGORITHM=HS256

DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=change-me
DB_SSLMODE=

CORS_ORIGINS=http://localhost:8051

# Email: use EMAIL_PROVIDER=dev for local logging. Use resend only with a real key in .env.
EMAIL_PROVIDER=dev
RESEND_API_KEY=
EMAIL_FROM=CronoFinanzas <no-reply@cronofinanzas.com>
APP_FRONTEND_URL=http://localhost:8051
